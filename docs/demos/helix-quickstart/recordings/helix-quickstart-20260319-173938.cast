[287.74569, "o", "\u001b[90mв”‚\u001b[0m\u001b[1;36m \u001b[0m\u001b[1;36m7             \u001b[0m\u001b[1;36m \u001b[0m\u001b[90mв”‚\u001b[0m\u001b[33m \u001b[0m\u001b[33m   \u001b[0m\u001b[33m \u001b[0m\u001b[90mв”‚\u001b[0m\u001b[32m \u001b[0m\u001b[32m        \u001b[0m\u001b[32m \u001b[0m\u001b[90mв”‚\u001b[0m\u001b[34m \u001b[0m\u001b[34m       \u001b[0m\u001b[34m \u001b[0m\u001b[90mв”‚\u001b[0m\u001b[1m \u001b[0m\u001b[1mflags)                                              \u001b[0m\u001b[1m \u001b[0m\u001b[90mв”‚\u001b[0m\r\n\u001b[90mв”‚\u001b[0m\u001b[1;36m \u001b[0m\u001b[1;36mhello-helix-0f\u001b[0m\u001b[1;36m \u001b[0m\u001b[90mв”‚\u001b[0m\u001b[33m \u001b[0m\u001b[33mP2 \u001b[0m\u001b[33m \u001b[0m\u001b[90mв”‚\u001b[0m\u001b[32m \u001b[0m\u001b[32mopen    \u001b[0m\u001b[32m \u001b[0m\u001b[90mв”‚\u001b[0m\u001b[34m \u001b[0m\u001b[34mtask   \u001b[0m\u001b[34m \u001b[0m\u001b[90mв”‚\u001b[0m\u001b[1m \u001b[0m\u001b[1mAdd CLI integration tests for AC-1 and AC-2         \u001b[0m\u001b[1m \u001b[0m\u001b[90mв”‚\u001b[0m\r\n\u001b[90mв”‚\u001b[0m\u001b[1;36m \u001b[0m\u001b[1;36m5             \u001b[0m\u001b[1;36m \u001b[0m\u001b[90mв”‚\u001b[0m\u001b[33m \u001b[0m\u001b[33m   \u001b[0m\u001b[33m \u001b[0m\u001b[90mв”‚\u001b[0m\u001b[32m \u001b[0m\u001b[32m        \u001b[0m\u001b[32m \u001b[0m\u001b[90mв”‚\u001b[0m\u001b[34m \u001b[0m\u001b[34m       \u001b[0m\u001b[34m \u001b[0m\u001b[90mв”‚\u001b[0m\u001b[1m \u001b[0m\u001b[1m                                                    \u001b[0m\u001b[1m \u001b[0m\u001b[90mв”‚\u001b[0m\r\n\u001b[90mв”‚\u001b[0m\u001b[1;36m \u001b[0m\u001b[1;36mhello-helix-c4\u001b[0m\u001b[1;36m \u001b[0m\u001b[90mв”‚\u001b[0m\u001b[32m \u001b[0m\u001b[32mP3 \u001b[0m\u001b[32m \u001b[0m\u001b[90mв”‚\u001b[0m\u001b[32m \u001b[0m\u001b[32mopen    \u001b[0m\u001b[32m \u001b[0m\u001b[90mв”‚\u001b[0m\u001b[34m \u001b[0m\u001b[34mtask   \u001b[0m\u001b[34m \u001b[0m\u001b[90mв”‚\u001b[0m\u001b[1m \u001b[0m\u001b[1mAdd toFahrenheit edge-case tests (negative,         \u001b[0m\u001b[1m \u001b[0m\u001b[90mв”‚\u001b[0m\r\n\u001b[90mв”‚\u001b[0m\u001b[1;36m \u001b[0m\u001b[1;36mr             \u001b[0m\u001b[1;36m \u001b[0m\u001b[90mв”‚\u001b[0m\u001b[32m \u001b[0m\u001b[32m   \u001b[0m\u001b[32m \u001b[0m\u001b[90mв”‚\u001b[0m\u001b[32m \u001b[0m\u001b[32m        \u001b[0m\u001b[32m \u001b[0m\u001b[90mв”‚\u001b[0m\u001b[34m \u001b[0m\u001b[34m       \u001b[0m\u001b[34m \u001b[0m\u001b[90mв”‚\u001b[0m\u001b[1m \u001b[0m\u001b[1mfractional, -...                                    \u001b[0m\u001b[1m \u001b[0m\u001b[90mв”‚\u001b[0m\r\n\u001b[90mв•°в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”ґв”Ђв”Ђв”Ђв”Ђв”Ђв”ґв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”ґв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”ґв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв•Ї\u001b[0m\r\n"]
