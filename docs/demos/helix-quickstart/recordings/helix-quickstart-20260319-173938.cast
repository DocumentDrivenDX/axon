[218.845709, "o", "#!/usr/bin/env node\r\n\r\nfunction toFahrenheit(c) {\r\n  return (c * 9/5) + 32;\r\n}\r\n\r\nfunction toCelsius(f) {\r\n  return (f - 32) * 5/9;\r\n}\r\n\r\nmodule.exports = { toFahrenheit, toCelsius };\r\n\r\nif (require.main === module) {\r\n  const args = process.argv.slice(2);\r\n  const celsiusIdx = args.indexOf('--to-celsius');\r\n"]
[218.845796, "o", "  const fahrenheitIdx = args.indexOf('--to-fahrenheit');\r\n\r\n  let result;\r\n\r\n  if (celsiusIdx !== -1) {\r\n    const value = parseFloat(args[celsiusIdx + 1]);\r\n    if (isNaN(value)) {\r\n      process.stderr.write('Error: invalid temperature value\\n');\r\n      process.exit(1);\r\n    }\r\n"]
[218.845935, "o", "...\r\n\r\n"]
