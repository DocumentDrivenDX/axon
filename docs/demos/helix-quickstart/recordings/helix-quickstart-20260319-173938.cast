[3.881027, "o", "\u001b[90mв•­в”Ђ\u001b[0m\u001b[90mв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\u001b[0m\u001b[90m \u001b[0mBeads Initialized\u001b[90m \u001b[0m\u001b[90mв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\u001b[0m\u001b[90mв”Ђв•®\u001b[0m\r\n\u001b[90mв”‚\u001b[0m \u001b[1mWorkspace initialized\u001b[0m                                                                            \u001b[90mв”‚\u001b[0m\r\n\u001b[90mв”‚\u001b[0m                                                                                                  \u001b[90mв”‚\u001b[0m\r\n\u001b[90mв”‚\u001b[0m \u001b[2mLocation: \u001b[0m\u001b[36m./.beads\u001b[0m                                                                               \u001b[90mв”‚\u001b[0m\r\n\u001b[90mв”‚\u001b[0m                                                                                                  \u001b[90mв”‚\u001b[0m\r\n\u001b[90mв”‚\u001b[0m \u001b[1mSteps:\u001b[0m                                                                                           \u001b[90mв”‚\u001b[0m\r\n\u001b[90mв”‚\u001b[0m \u001b[1;32m[+] \u001b[0m\u001b[1m.beads/ directory\u001b[0m                                                                            \u001b[90mв”‚\u001b[0m\r\n\u001b[90mв”‚\u001b[0m \u001b[1;32m[+] \u001b[0m\u001b[1mSQLite database (beads.db)\u001b[0m                                                                   \u001b[90mв”‚\u001b[0m\r\n\u001b[90mв”‚\u001b[0m \u001b[1;32m[+] \u001b[0m\u001b[1mmetadata.json\u001b[0m                                                                                \u001b[90mв”‚\u001b[0m\r\n\u001b[90mв”‚\u001b[0m \u001b[1;32m[+] \u001b[0m\u001b[1mconfig.yaml\u001b[0m                                                                                  \u001b[90mв”‚\u001b[0m\r\n\u001b[90mв”‚\u001b[0m \u001b[1;32m[+] \u001b[0m\u001b[1m.gitignore\u001b[0m                                                                                   \u001b[90mв”‚\u001b[0m\r\n\u001b[90mв”‚\u001b[0m \u001b[1;32m[+] \u001b[0m\u001b[1missues.jsonl (for bv compatibility)\u001b[0m                                                          \u001b[90mв”‚\u001b[0m\r\n\u001b[90mв”‚\u001b[0m \u001b[1;33m[*] \u001b[0m\u001b[1mIssue prefix set to 'hello-helix'\u001b[0m                                                            \u001b[90mв”‚\u001b[0m\r\n\u001b[90mв”‚\u001b[0m                                                                                                  \u001b[90mв”‚\u001b[0m\r\n\u001b[90mв”‚\u001b[0m \u001b[1mLayout:\u001b[0m                                                                                          \u001b[90mв”‚\u001b[0m\r\n\u001b[90mв”‚\u001b[0m   .beads/                                                                                        \u001b[90mв”‚\u001b[0m\r\n\u001b[90mв”‚\u001b[0m     |-- beads.db                                                                                 \u001b[90mв”‚\u001b[0m\r\n\u001b[90mв”‚\u001b[0m     |-- metadata.json                                                                            \u001b[90mв”‚\u001b[0m\r\n\u001b[90mв”‚\u001b[0m     |-- config.yaml                                                                              \u001b[90mв”‚\u001b[0m\r\n\u001b[90mв”‚\u001b[0m     |-- .gitignore                                                                               \u001b[90mв”‚\u001b[0m\r\n\u001b[90mв”‚\u001b[0m     `-- issues.jsonl                                                                             \u001b[90mв”‚\u001b[0m\r\n\u001b[90mв”‚\u001b[0m                                                                                                  \u001b[90mв”‚\u001b[0m\r\n\u001b[90mв”‚\u001b[0m \u001b[1mNext steps:\u001b[0m                                                                                      \u001b[90mв”‚\u001b[0m\r\n\u001b[90