[8.855874, "o", "$ claude --plugin-dir /ddx-library -p --no-session-persistence Say 'DDx plugin loaded' and list the available /ddx: slash commands. Be brief.\r\n"]
[15.971269, "o", "\r\n\r\nDDx plugin loaded. Available `/ddx:` slash commands:\r\n\r\n- `/ddx:code-review` вЂ” Thorough code review with security focus\r\n- `/ddx:commit-hooks` вЂ” Design and implement git commit hooks\r\n- `/ddx:create-workflow` вЂ” Create a new DDx workflow interactively\r\n- `/ddx:docs` вЂ” Create and maintain project documentation\r\n- `/ddx:github-actions` вЂ” Design and implement GitHub Actions CI/CD\r\n- `/ddx:prd` вЂ” Create a Product Requirements Document\r\n- `/ddx:gitignore` вЂ” Evaluate and create a comprehensive .gitignore\r\n- `/ddx:helix` вЂ” HELIX test-first development workflow\r\n- `/ddx:helix-alignment-review` вЂ” Top-down reconciliation review of a HELIX project\r\n"]
