{
	"name": "axon-admin-ui",
	"version": "0.1.0",
	"private": true,
	"packageManager": "bun@1.3.11",
	"scripts": {
		"dev": "vite dev",
		"build": "svelte-kit sync && vite build",
		"preview": "vite preview",
		"typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"lint": "bunx biome check biome.json package.json svelte.config.js tsconfig.json vite.config.js src",
		"test": "bun test src/",
		"test:e2e": "cd .. && AXON_E2E_STORAGE=postgres scripts/test-ui-e2e-docker.sh",
		"test:e2e:real": "cd .. && scripts/test-ui-e2e-docker.sh",
		"test:e2e:postgres": "cd .. && AXON_E2E_STORAGE=postgres scripts/test-ui-e2e-docker.sh",
		"test:e2e:sqlite": "cd .. && AXON_E2E_STORAGE=sqlite scripts/test-ui-e2e-docker.sh"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-static": "^3.0.0",
		"@sveltejs/kit": "^2.0.0",
		"@types/bun": "^1.3.11",
		"@types/node": "^24.0.0",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"typescript": "^5.0.0",
		"vite": "^6.0.0"
	},
	"type": "module"
}
