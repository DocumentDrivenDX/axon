{
	"extends": "./.svelte-kit/tsconfig.json",
	"compilerOptions": {
		"allowJs": false,
		"exactOptionalPropertyTypes": true,
		"moduleResolution": "bundler",
		"noUncheckedIndexedAccess": true,
		"skipLibCheck": true,
		"strict": true,
		"types": ["bun", "node"],
		"verbatimModuleSyntax": true
	}
}
